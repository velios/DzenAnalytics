.claude/skills/
skills-lock.json

# Dev-only logging sink — Vite middleware writes JSON request logs
# here when the app calls `devLog()`. Useful for debugging server-side
# Zenmoney push errors without staring at DevTools. Gitignored — no
# production data ever lands here.
dev-logs/

# env files
.env
.*.env
