# Опциональный вход через внешний провайдер токена (zen-platform / SSO).
# Не задан — приложение работает как апстрим: ручной токен + CSV.
# Подробности и поведение: README → «Вход через zen-platform».

# Откуда взять токен Zenmoney по cookie сессии (credentials: 'include').
# Same-origin путь рекомендуется (CORS не задействован):
VITE_TOKEN_PROVIDER_URL=/api/me/zenmoney-token

# Куда вести на вход / смену пользователя. Приложение само добавит
# ?redirect_to=<текущий_url>.
VITE_LOGIN_URL=https://auth.zentable.ru/

# Полный выход из SSO: POST по этому URL с credentials:'include', ожидается
# {ok:true} (завершает серверную сессию). Same-origin путь — на этот origin
# должна быть проброшена ручка (Caddy: /api/auth/logout → монолит). Не задан —
# кнопка делает только локальный disconnect (opt-out), сессия на сервере живёт.
VITE_LOGOUT_URL=/api/auth/logout
